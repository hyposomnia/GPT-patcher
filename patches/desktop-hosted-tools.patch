+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn api_key_custom_provider_uses_hosted_tools_in_standard_responses() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = responses::start_mock_server().await;
+    let response_mock = responses::mount_sse_once(
+        &server,
+        responses::sse(vec![
+            responses::ev_response_created("resp-1"),
+            responses::ev_completed("resp-1"),
+        ]),
+    )
+    .await;
+
+    let auth = CodexAuth::from_api_key("dummy");
+    let extensions = responses_extensions(&auth);
+    let mut builder = test_codex()
+        .with_auth(auth)
+        .with_extensions(extensions)
+        .with_model_info_override("gpt-5.4", |model_info| {
+            model_info.use_responses_lite = true;
+            configure_image_capable_model(model_info);
+        })
+        .with_config(|config| {
+            configure_responses_tools(config);
+            config.model_provider.name = "custom".to_string();
+            config.model_provider.requires_openai_auth = true;
+        });
+    let test = builder.build(&server).await?;
+
+    test.submit_turn("Use hosted tools").await?;
+
+    let request = response_mock.single_request();
+    assert_eq!(request.header(RESPONSES_LITE_HEADER), None);
+    let body = request.body_json();
+    let tools = body["tools"]
+        .as_array()
+        .context("standard Responses request should include tools")?;
+    assert!(has_hosted_tool(tools, "web_search"));
+    assert!(has_namespaced_tool(tools, "image_gen", "imagegen"));
+
+    Ok(())
+}
